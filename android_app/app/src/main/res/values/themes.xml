<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- ==========================================
         DARK THEME - Digit Recognition App
         Material 3 mit WCAG 2.1 AA Accessibility
         ========================================== -->
    <style name="Base.Theme.Audio_digit_app" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary colors (Blau) -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary colors (Grün/Accent) -->
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Background and surface (Dark Theme) -->
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorSurfaceVariant">@color/colorSurfaceVariant</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Error and Warning colors -->
        <item name="colorError">@color/colorError</item>
        <item name="colorOnError">@color/white</item>

        <!-- Material 3 Dialog Button Textfarbe (WCAG AA fix) -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.App.MaterialAlertDialog</item>

        <!-- Status bar und Navigation bar -->
        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:navigationBarColor">@color/colorBackground</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>

        <!-- Window Background -->
        <item name="android:windowBackground">@color/colorBackground</item>

        <!-- Material 3 Button Styling -->
        <item name="materialButtonStyle">@style/Widget.App.Button</item>
        <item name="materialCardViewStyle">@style/Widget.App.CardView</item>
    </style>

    <style name="Theme.Audio_digit_app" parent="Base.Theme.Audio_digit_app" />

    <!-- ==========================================
         BUTTON STYLES
         ========================================== -->
    <style name="Widget.App.Button" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="Widget.App.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="strokeColor">@color/colorPrimary</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="Widget.App.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <!-- ==========================================
         MODE BUTTON STYLES (120-140dp große runde Buttons)
         ========================================== -->
    <style name="Widget.App.ModeButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">140dp</item>
        <item name="android:layout_height">140dp</item>
        <item name="android:gravity">center</item>
        <item name="cornerRadius">70dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">48dp</item>
        <item name="rippleColor">@color/ripple_primary</item>
        <item name="elevation">8dp</item>
    </style>

    <style name="Widget.App.ModeButton.Digit">
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="iconTint">@color/text_on_primary</item>
    </style>

    <style name="Widget.App.ModeButton.Pin">
        <item name="backgroundTint">@color/colorAccent</item>
        <item name="android:textColor">@color/text_on_accent</item>
        <item name="iconTint">@color/text_on_accent</item>
    </style>

    <!-- ==========================================
         CARD STYLES
         ========================================== -->
    <style name="Widget.App.CardView" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/colorSurface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="Widget.App.CardView.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardBackgroundColor">@color/colorSurface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.App.CardView.Result" parent="Widget.App.CardView">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">8dp</item>
    </style>

    <!-- ==========================================
         TEXT STYLES (WCAG AA Kontrast)
         ========================================== -->
    <style name="TextAppearance.App.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">24sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.App.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="TextAppearance.App.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TextAppearance.App.Label" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/text_hint</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextAppearance.App.DigitResult" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:textColor">@color/result_digit</item>
        <item name="android:textSize">96sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.App.PinResult" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/result_pin</item>
        <item name="android:textSize">48sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.2</item>
    </style>

    <style name="TextAppearance.App.Status" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">18sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- ==========================================
         DEBUG PANEL STYLES
         ========================================== -->
    <style name="Widget.App.CardView.Debug" parent="Widget.App.CardView.Outlined">
        <item name="cardBackgroundColor">@color/debug_bg</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="strokeColor">@color/debug_border</item>
    </style>

    <style name="TextAppearance.App.Debug" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/debug_text</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <style name="TextAppearance.App.Debug.Accent">
        <item name="android:textColor">@color/debug_accent</item>
    </style>

    <!-- ==========================================
         DIALOG STYLES (WCAG AA für Buttons)
         ========================================== -->
    <style name="ThemeOverlay.App.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="buttonBarNegativeButtonStyle">@style/Widget.App.Button.TextButton.Dialog</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.App.Button.TextButton.Dialog</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget.App.Button.TextButton.Dialog</item>
    </style>

    <style name="Widget.App.Button.TextButton.Dialog" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/colorAccent</item>
    </style>

    <!-- ==========================================
         LIGHT THEME VARIANT
         ========================================== -->
    <style name="Theme.Audio_digit_app.Light" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary_light</item>
        <item name="colorPrimaryVariant">@color/colorPrimary_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/colorAccent_light</item>
        <item name="colorSecondaryVariant">@color/colorAccent_light</item>
        <item name="colorOnSecondary">@color/on_secondary_light</item>
        <item name="android:colorBackground">@color/colorBackground_light</item>
        <item name="colorSurface">@color/colorSurface_light</item>
        <item name="colorSurfaceVariant">@color/colorSurfaceVariant_light</item>
        <item name="colorOnSurface">@color/text_primary_light</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary_light</item>
        <item name="colorError">@color/status_error_light</item>
        <item name="colorOnError">@color/white</item>
        <item name="android:statusBarColor">@color/colorBackground_light</item>
        <item name="android:navigationBarColor">@color/colorBackground_light</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowBackground">@color/colorBackground_light</item>
        <item name="materialButtonStyle">@style/Widget.App.Button.Light</item>
        <item name="materialCardViewStyle">@style/Widget.App.CardView.Light</item>
    </style>

    <style name="Widget.App.Button.Light" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/colorPrimary_light</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="Widget.App.CardView.Light" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/colorSurface_light</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeColor">@color/colorSurfaceVariant_light</item>
        <item name="strokeWidth">0dp</item>
    </style>
</resources>
