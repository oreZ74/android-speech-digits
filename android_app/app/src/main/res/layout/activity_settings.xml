<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Feedback Section Header -->
        <TextView
            android:id="@+id/textFeedbackHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_feedback_header"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="8dp"
            android:importantForAccessibility="yes"
            android:accessibilityHeading="true" />

        <!-- Sound Feedback Switch -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchSound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_sound_label"
            android:minHeight="48dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:contentDescription="@string/settings_sound_description"
            app:switchPadding="16dp" />

        <TextView
            android:id="@+id/textSoundHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_sound_hint"
            android:textSize="14sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp"
            android:textColor="?android:attr/textColorSecondary" />

        <!-- Vibration Feedback Switch -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchVibration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_vibration_label"
            android:minHeight="48dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:contentDescription="@string/settings_vibration_description"
            app:switchPadding="16dp" />

        <TextView
            android:id="@+id/textVibrationHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_vibration_hint"
            android:textSize="14sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp"
            android:textColor="?android:attr/textColorSecondary" />

        <!-- Accessibility Note -->
        <TextView
            android:id="@+id/textAccessibilityNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_accessibility_note"
            android:textSize="14sp"
            android:paddingTop="16dp"
            android:textColor="?android:attr/textColorSecondary"
            android:textStyle="italic" />

        <!-- Theme Section Header -->
        <TextView
            android:id="@+id/textThemeHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_theme_header"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingTop="24dp"
            android:paddingBottom="8dp"
            android:importantForAccessibility="yes"
            android:accessibilityHeading="true" />

        <TextView
            android:id="@+id/textThemeDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_theme_description"
            android:textSize="14sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="12dp"
            android:textColor="?android:attr/textColorSecondary" />

        <!-- Dark Theme Radio -->
        <RadioButton
            android:id="@+id/radioThemeDark"
            style="@style/Widget.Material3.CompoundButton.RadioButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_theme_dark"
            android:minHeight="48dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <!-- Light Theme Radio -->
        <RadioButton
            android:id="@+id/radioThemeLight"
            style="@style/Widget.Material3.CompoundButton.RadioButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_theme_light"
            android:minHeight="48dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <!-- System Theme Radio -->
        <RadioButton
            android:id="@+id/radioThemeSystem"
            style="@style/Widget.Material3.CompoundButton.RadioButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_theme_system"
            android:minHeight="48dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <!-- Language Section Header -->
        <TextView
            android:id="@+id/textLanguageHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_language_header"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingTop="24dp"
            android:paddingBottom="8dp"
            android:importantForAccessibility="yes"
            android:accessibilityHeading="true" />

        <TextView
            android:id="@+id/textLanguageDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_language_description"
            android:textSize="14sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="12dp"
            android:textColor="?android:attr/textColorSecondary" />

        <!-- System Language Radio -->
        <RadioButton
            android:id="@+id/radioLanguageSystem"
            style="@style/Widget.Material3.CompoundButton.RadioButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_language_system"
            android:minHeight="48dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <!-- German Language Radio -->
        <RadioButton
            android:id="@+id/radioLanguageGerman"
            style="@style/Widget.Material3.CompoundButton.RadioButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_language_german"
            android:minHeight="48dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <!-- English Language Radio -->
        <RadioButton
            android:id="@+id/radioLanguageEnglish"
            style="@style/Widget.Material3.CompoundButton.RadioButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_language_english"
            android:minHeight="48dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <!-- Live Region Announcement View für Settings -->
        <TextView
            android:id="@+id/a11yAnnouncement"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="invisible"
            android:accessibilityLiveRegion="polite"
            android:importantForAccessibility="yes"
            android:focusable="false"
            android:textSize="1sp" />

    </LinearLayout>
</ScrollView>
